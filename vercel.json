{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "pnpm vercel-build",
  "outputDirectory": "dist",
  "installCommand": "pnpm install",
  "framework": null,
  "rewrites": [
    { "source": "/okr/:path*", "destination": "/okr/index.html" },
    { "source": "/((?!okr/).*)", "destination": "/index.html" }
  ]
}
