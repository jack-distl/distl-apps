# Supabase connection (get these from your Supabase project settings → API)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Supabase service role key (for serverless functions — bypasses RLS)
# Find this in Supabase dashboard → Settings → API → service_role key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# WorkflowMax by BlueRock OAuth
# Create an app at https://developer.workflowmax.com/apps
WFM_CLIENT_ID=your-wfm-app-client-id
WFM_CLIENT_SECRET=your-wfm-app-client-secret
WFM_REDIRECT_URI=https://your-vercel-url/api/wfm/callback
